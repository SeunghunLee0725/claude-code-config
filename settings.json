      "Bash(git reset --hard origin/master*)",
      "Bash(git clean -fdx*)",
      "Bash(chmod -R 777 *)",
      "Bash(:(){ :|:& };:*)",
      "Bash(mkfs *)",
      "Bash(dd if=* of=/dev/*)",
      "Bash(> /dev/sda*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Bash(pip install --break-system-packages*)"
